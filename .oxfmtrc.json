{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "experimentalSortImports": {
    "groups": [
      "type-import",
      "value-builtin",
      "value-external",
      "value-internal"
    ]
  },
  "experimentalTailwindcss": {
    "functions": ["cn", "clsx"]
  }
}
