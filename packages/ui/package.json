{
  "name": "@openstatus/ui",
  "version": "0.0.0",
  "license": "MIT",
  "exports": {
    "./components/ui/*": {
      "types": "./src/components/ui/*.tsx",
      "default": "./src/components/ui/*.tsx"
    },
    "./components/blocks/status.types": {
      "types": "./src/components/blocks/status.types.ts",
      "default": "./src/components/blocks/status.types.ts"
    },
    "./components/blocks/status.utils": {
      "types": "./src/components/blocks/status.utils.ts",
      "default": "./src/components/blocks/status.utils.ts"
    },
    "./components/blocks/*": {
      "types": "./src/components/blocks/*.tsx",
      "default": "./src/components/blocks/*.tsx"
    },
    "./components/custom/*": {
      "types": "./src/components/custom/*.tsx",
      "default": "./src/components/custom/*.tsx"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "default": "./src/lib/*.ts"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    },
    "./globals": "./src/globals.css"
  },
  "scripts": {
    "build": "echo '@openstatus/ui has no build step (registry builds separately)'",
    "registry:build": "node scripts/transform-imports.mjs && shadcn build --cwd dist --output public/r registry.json && node scripts/copy-to-web.mjs",
    "lint": "biome lint \"**/*.ts*\"",
    "tsc": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@openstatus/tsconfig": "workspace:*",
    "@types/luxon": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "glob": "catalog:",
    "shadcn": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@date-fns/utc": "catalog:",
    "@dnd-kit/core": "catalog:",
    "@dnd-kit/modifiers": "catalog:",
    "@dnd-kit/sortable": "catalog:",
    "@dnd-kit/utilities": "catalog:",
    "@hookform/resolvers": "catalog:",
    "@radix-ui/react-accordion": "catalog:",
    "@radix-ui/react-alert-dialog": "catalog:",
    "@radix-ui/react-avatar": "catalog:",
    "@radix-ui/react-checkbox": "catalog:",
    "@radix-ui/react-collapsible": "catalog:",
    "@radix-ui/react-context-menu": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-hover-card": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-navigation-menu": "catalog:",
    "@radix-ui/react-popover": "catalog:",
    "@radix-ui/react-progress": "catalog:",
    "@radix-ui/react-radio-group": "catalog:",
    "@radix-ui/react-scroll-area": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-separator": "catalog:",
    "@radix-ui/react-slider": "catalog:",
