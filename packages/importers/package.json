{
  "name": "@openstatus/importers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./statuspage": "./src/providers/statuspage/index.ts",
    "./statuspage/fixtures": "./src/providers/statuspage/fixtures.ts",
    "./betterstack": "./src/providers/betterstack/index.ts",
    "./betterstack/fixtures": "./src/providers/betterstack/fixtures.ts",
