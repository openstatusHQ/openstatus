TAGS "external_status_reports"

NODE daily
SQL >

    %
    SELECT
        day,
        uniqMerge(reporters) AS reporters,
        sumMerge(total) AS total
    FROM mv__external_status_reports_daily__v0
    WHERE id = {{ String(id) }}
    {% if defined(days) %}
        AND day >= today() - INTERVAL {{ Int16(days, 45) }} DAY
    {% end %}
    GROUP BY day
    ORDER BY day ASC

TYPE ENDPOINT
