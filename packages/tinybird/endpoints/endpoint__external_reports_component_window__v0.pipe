TAGS "external_status_reports"

NODE component_window
SQL >

    %
    SELECT
        component_id,
        uniq(reporter_hash) AS reporters,
        count() AS total
    FROM external_status_reports__v0
    WHERE id = {{ String(id) }}
        AND component_id != ''
        AND reported_at >= {{ Int64(since, 0) }}
    GROUP BY component_id

TYPE ENDPOINT
