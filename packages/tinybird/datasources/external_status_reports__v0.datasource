SCHEMA >
    `id` String `json:$.id`,
    `component_id` String `json:$.component_id`,
    `reporter_hash` String `json:$.reporter_hash`,
    `country` String `json:$.country`,
    `reported_at` Int64 `json:$.reported_at`

ENGINE "MergeTree"
ENGINE_SORTING_KEY "id, reported_at"
ENGINE_TTL "toDateTime(fromUnixTimestamp64Milli(reported_at)) + INTERVAL 60 DAY"
