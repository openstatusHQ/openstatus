# Data Source created from Pipe 'aggregate__external_status_reports_daily__v0'

SCHEMA >
    `day` Date,
    `id` String,
    `component_id` String,
    `reporters` AggregateFunction(uniq, String),
    `total` AggregateFunction(sum, UInt32)

ENGINE "AggregatingMergeTree"
ENGINE_PARTITION_KEY "toYYYYMM(day)"
ENGINE_SORTING_KEY "id, component_id, day"
