{
  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": null,
          "run": "onSave"
        }
      }
    }
  },
  "languages": {
    "TypeScript": {
      "language_servers": [
        "vtsls",
        "oxlint",
        "oxfmt",
        "tailwindcss-language-server"
      ],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
      "code_actions_on_format": { "source.fixAll.oxc": true },
      "prettier": { "allowed": false }
    },
    "TSX": {
      "language_servers": [
        "vtsls",
        "oxlint",
        "oxfmt",
        "tailwindcss-language-server"
      ],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
      "code_actions_on_format": { "source.fixAll.oxc": true },
      "prettier": { "allowed": false }
    },
    "JavaScript": {
      "language_servers": [
        "vtsls",
        "oxlint",
        "oxfmt",
        "tailwindcss-language-server"
      ],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
      "code_actions_on_format": { "source.fixAll.oxc": true },
      "prettier": { "allowed": false }
    },
    "JSON": {
      "language_servers": ["json-language-server", "oxfmt"],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
      "prettier": { "allowed": false }
    },
    "JSONC": {
      "language_servers": ["json-language-server", "oxfmt"],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
      "prettier": { "allowed": false }
    },
    "CSS": {
      "language_servers": ["tailwindcss-language-server", "oxfmt"],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
      "prettier": { "allowed": false }
    },
    "SCSS": {
      "language_servers": ["tailwindcss-language-server", "oxfmt"],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
      "prettier": { "allowed": false }
    },
    "HTML": {
      "language_servers": ["oxfmt"],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
      "prettier": { "allowed": false }
    },
    "Markdown": {
      "language_servers": ["oxfmt"],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
      "prettier": { "allowed": false }
    },
    "MDX": {
      "language_servers": ["oxfmt"],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
      "prettier": { "allowed": false }
    },
    "YAML": {
      "language_servers": ["yaml-language-server", "oxfmt"],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
      "prettier": { "allowed": false }
    }
  }
}
